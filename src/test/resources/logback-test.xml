<configuration debug="false">
    <statusListener class="ch.qos.logback.core.status.NopStatusListener" />

    <!-- CONSOLE - For lokal kjøring -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%msg%n</pattern>
        </encoder>
    </appender>

    <!-- SILENT CONSOLE - Kun ERROR vises under tester -->
    <appender name="SILENT" class="ch.qos.logback.core.ConsoleAppender">
        <filter class="ch.qos.logback.classic.filter.ThresholdFilter">
            <level>ERROR</level>
        </filter>
        <encoder>
            <pattern>%msg%n</pattern>
        </encoder>
    </appender>

    <!-- OppstartLoggConfig - tillat INFO for lokal kjøring -->
    <logger name="no.nav.gjenlevende.bs.sak.config.OppstartLoggConfig" level="INFO" additivity="false">
        <appender-ref ref="CONSOLE" />
    </logger>

    <!-- Alt annet settes til ERROR - kun feil vises -->
    <root level="ERROR">
        <appender-ref ref="SILENT" />
    </root>
</configuration>
